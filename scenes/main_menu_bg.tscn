[sub_resource type="GDScript" id="GDScript_squgt"]
script/source = "extends Node3D

@onready var sky_3d: Sky3D = $Sky3D

func _ready() -> void:
	_update()
	
	var tick_timer:Timer = Timer.new()
	tick_timer.wait_time = 15.0
	tick_timer.one_shot = false
	tick_timer.timeout.connect(_update)
	add_child(tick_timer)
	tick_timer.start()

func _update() -> void:
	var current_time:float = Time.get_time_dict_from_system().get(\"hour\")
	sky_3d.current_time = current_time
"

